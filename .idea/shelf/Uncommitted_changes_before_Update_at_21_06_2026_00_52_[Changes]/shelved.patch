+        int passes = 0;
+        while (true){
+            passes = 0;
+            for (int i = 0; i < input.size()-1; i++){
+                if (input.get(i) < input.get(i+1)){passes++;}
+            }
+            if  (passes >= input.size()-1){
+                break;
+            } else {
+                for (int i = 0; i < input.size()/2; i++){
